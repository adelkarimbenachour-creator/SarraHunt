# Database Connection (for Drizzle ORM)
# Format: postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@your-project.pooler.supabase.com:5432/postgres

# GitHub API Token (optional, for higher rate limits)
GITHUB_TOKEN=your-github-token

# GitHub OAuth for Auth.js (Sign in with GitHub)
# Get these from https://github.com/settings/developers
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret
AUTH_SECRET=your-auth-secret-key # Generate with `openssl rand -base64 32`
